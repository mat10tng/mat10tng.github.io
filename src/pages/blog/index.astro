---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const sessions = (await getCollection('sessions')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const introPost = allPosts.find(p => p.id === '2026-04-12-who-writes-this');
const posts = allPosts.filter(p => p.id !== '2026-04-12-who-writes-this');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Posts — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 1rem;
			}
			.intro-post {
				margin-bottom: 2rem;
				padding: 1.25rem;
				border: 1px solid rgba(var(--gray), 0.15);
				border-radius: 8px;
			}
			.intro-post a {
				text-decoration: none;
				display: block;
			}
			.intro-title {
				font-size: 1.1rem;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0 0 0.25rem;
				transition: color 0.2s;
			}
			.intro-post a:hover .intro-title {
				color: rgb(var(--accent));
			}
			.intro-desc {
				font-size: 0.9rem;
				color: rgb(var(--gray-dark, #444));
				margin: 0;
				line-height: 1.5;
			}
			.intro {
				color: rgb(var(--gray));
				font-size: 0.95rem;
				margin-bottom: 2rem;
				line-height: 1.6;
			}
			.section-title {
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
				margin-bottom: 1rem;
				padding-bottom: 0.5rem;
				border-bottom: 1px solid rgba(var(--gray), 0.2);
			}
			.session-list, .post-list {
				list-style: none;
				margin: 0 0 2.5rem;
				padding: 0;
			}
			.session-item {
				margin-bottom: 1.25rem;
				padding-bottom: 1.25rem;
				border-bottom: 1px solid rgba(var(--gray), 0.1);
			}
			.session-item:last-child {
				border-bottom: none;
			}
			.session-item a, .post-item a {
				text-decoration: none;
				display: block;
			}
			.session-title {
				font-size: 1rem;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0 0 0.25rem;
				transition: color 0.2s;
			}
			.session-item a:hover .session-title,
			.post-item a:hover .post-title {
				color: rgb(var(--accent));
			}
			.session-desc {
				font-size: 0.9rem;
				color: rgb(var(--gray-dark, #444));
				line-height: 1.5;
				margin: 0 0 0.35rem;
			}
			.session-phases {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
			}
			.phase-tag {
				font-size: 0.7rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: rgb(var(--gray));
				padding: 0.15rem 0.4rem;
				border: 1px solid rgba(var(--gray), 0.2);
				border-radius: 3px;
			}
			.session-date {
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}
			.post-item {
				margin-bottom: 0.75rem;
			}
			.post-title {
				font-size: 1rem;
				font-weight: 500;
				color: rgb(var(--black));
				margin: 0;
				transition: color 0.2s;
			}
			.post-meta {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				margin: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{introPost && (
				<div class="intro-post">
					<a href={`/blog/${introPost.id}/`}>
						<p class="intro-title">{introPost.data.title}</p>
						<p class="intro-desc">{introPost.data.description}</p>
					</a>
				</div>
			)}

			<p class="intro">
				sessions walk through a complete work cycle — what happened, what was captured, what improved. standalone posts pull out a single idea.
			</p>

			<div class="section-title">sessions</div>
			<ul class="session-list">
				{sessions.map(s => (
					<li class="session-item">
						<a href={`/session/${s.id}/`}>
							<p class="session-title">{s.data.title}</p>
							<p class="session-desc">{s.data.description}</p>
							<div class="session-phases">
								<span class="phase-tag">work</span>
								<span class="phase-tag">capture</span>
								<span class="phase-tag">review</span>
								<span class="phase-tag">improve</span>
								{s.data.measure && <span class="phase-tag">measure</span>}
							</div>
							<span class="session-date">{s.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</span>
						</a>
					</li>
				))}
			</ul>

			<div class="section-title">standalone posts</div>
			<ul class="post-list">
				{posts.map(post => (
					<li class="post-item">
						<a href={`/blog/${post.id}/`}>
							<p class="post-title">{post.data.title}</p>
							<p class="post-meta">{post.data.description}</p>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
