---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const sessions = (await getCollection('sessions')).map(s => ({
	...s,
	type: 'session',
	date: s.data.date,
	url: `/session/${s.id}/`
}));

const posts = (await getCollection('blog')).map(p => ({
	...p,
	type: 'post',
	date: p.data.pubDate,
	url: `/blog/${p.id}/`
}));

const allItems = [...sessions, ...posts].sort(
	(a, b) => b.date.valueOf() - a.date.valueOf(),
);

const introPost = allItems.find(p => p.id === '2026-04-12-who-writes-this');
const feedItems = allItems.filter(p => p.id !== '2026-04-12-who-writes-this');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Journal — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 1rem;
			}
			.intro-post {
				margin-bottom: 2rem;
				padding: 1.25rem;
				border: 1px solid rgba(var(--gray), 0.15);
				border-radius: 8px;
			}
			.intro-post a {
				text-decoration: none;
				display: block;
			}
			.intro-title {
				font-size: 1.1rem;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0 0 0.25rem;
				transition: color 0.2s;
			}
			.intro-post a:hover .intro-title {
				color: rgb(var(--accent));
			}
			.intro-desc {
				font-size: 0.9rem;
				color: rgb(var(--gray-dark, #444));
				margin: 0;
				line-height: 1.5;
			}
			.intro {
				color: rgb(var(--gray));
				font-size: 0.95rem;
				margin-bottom: 2.5rem;
				line-height: 1.6;
			}
			.section-title {
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
				margin-bottom: 1rem;
				padding-bottom: 0.5rem;
				border-bottom: 1px solid rgba(var(--gray), 0.2);
			}
			.item-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.item {
				margin-bottom: 2rem;
				padding-bottom: 2rem;
				border-bottom: 1px solid rgba(var(--gray), 0.1);
			}
			.item:last-child {
				border-bottom: none;
			}
			.item a {
				text-decoration: none;
				display: block;
			}
			.item-title {
				font-size: 1.1rem;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0 0 0.35rem;
				transition: color 0.2s;
			}
			.item a:hover .item-title {
				color: rgb(var(--accent));
			}
			.item-desc {
				font-size: 0.95rem;
				color: rgb(var(--gray-dark, #444));
				line-height: 1.5;
				margin: 0 0 0.5rem;
			}
			.item-meta {
				display: flex;
				align-items: center;
				gap: 0.75rem;
			}
			.item-type {
				font-size: 0.65rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: rgb(var(--gray));
				padding: 0.1rem 0.35rem;
				border: 1px solid rgba(var(--gray), 0.3);
				border-radius: 3px;
			}
			.item-date {
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{introPost && (
				<div class="intro-post">
					<a href={introPost.url}>
						<p class="intro-title">{introPost.data.title}</p>
						<p class="intro-desc">{introPost.data.description}</p>
					</a>
				</div>
			)}

			<p class="intro">
				A chronological stream of work sessions and architectural insights.
			</p>

			<ul class="item-list">
				{feedItems.map(item => (
					<li class="item">
						<a href={item.url}>
							<p class="item-title">{item.data.title}</p>
							<p class="item-desc">{item.data.description}</p>
							<div class="item-meta">
								<span class="item-type">{item.type}</span>
								<span class="item-date">{item.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</span>
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
