---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const sessions = await getCollection('sessions');
	return sessions.map((session) => ({
		params: { slug: session.id },
		props: session,
	}));
}

const session = Astro.props;
const { Content } = await render(session);
const { title, description, date, work, capture, review, improve, measure } = session.data;

const phases = [
	{ name: 'work', hint: 'what was happening', text: work, href: '/work' },
	{ name: 'capture', hint: 'what the data showed', text: capture, href: '/capture' },
	{ name: 'review', hint: 'what pattern emerged', text: review, href: '/review' },
	{ name: 'improve', hint: 'what changed', text: improve, href: '/improve' },
];
if (measure) {
	phases.push({ name: 'measure', hint: 'did it work', text: measure, href: '/measure' });
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} />
		<style>
			article {
				max-width: 720px;
				margin: 2rem auto;
				padding: 0 1rem;
				overflow-x: hidden;
			}
			.session-date {
				font-size: 0.85rem;
				color: rgb(var(--gray));
			}
			h1 {
				margin: 0.25rem 0 1.5rem;
			}
			.phase-timeline {
				display: flex;
				flex-direction: column;
				gap: 0;
				margin-bottom: 2.5rem;
				border-left: 2px solid #e8e8e8;
				padding-left: 1.25rem;
			}
			.phase-item {
				position: relative;
				padding: 0.6rem 0;
			}
			.phase-item::before {
				content: '';
				position: absolute;
				left: -1.45rem;
				top: 1rem;
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: #ccc;
				border: 2px solid #fff;
			}
			.phase-item:last-child {
				border-bottom: none;
			}
			.phase-header {
				display: flex;
				align-items: baseline;
				gap: 0.5rem;
				margin-bottom: 0.2rem;
			}
			.phase-label {
				font-size: 0.7rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: rgb(var(--accent));
				text-decoration: none;
				min-width: 52px;
			}
			.phase-label:hover {
				text-decoration: underline;
			}
			.phase-hint {
				font-size: 0.7rem;
				color: #aaa;
			}
			.phase-text {
				font-size: 0.88rem;
				line-height: 1.55;
				color: rgb(var(--gray-dark));
			}
			.session-body {
				line-height: 1.7;
			}
			.session-body h3 {
				margin-top: 2rem;
			}

			/* code blocks: no horizontal scroll, copy button */
			.session-body pre {
				position: relative;
				white-space: pre-wrap;
				word-wrap: break-word;
				overflow-x: hidden;
				background: #f6f6f6;
				border: 1px solid #e8e8e8;
				border-radius: 6px;
				padding: 1rem;
				font-size: 0.82rem;
				line-height: 1.5;
				max-width: 100%;
			}
			.session-body pre code {
				white-space: pre-wrap;
				word-wrap: break-word;
			}
			.copy-btn {
				position: absolute;
				top: 0.5rem;
				right: 0.5rem;
				padding: 0.25rem 0.6rem;
				font-size: 0.7rem;
				background: #fff;
				border: 1px solid #ddd;
				border-radius: 4px;
				cursor: pointer;
				color: #666;
				transition: all 150ms;
			}
			.copy-btn:hover {
				background: #f0f0f0;
				color: #333;
			}
			.copy-btn.copied {
				background: #2563eb;
				color: #fff;
				border-color: #2563eb;
			}

			/* tables: fit within width */
			.session-body table {
				width: 100%;
				border-collapse: collapse;
				font-size: 0.85rem;
				table-layout: fixed;
			}
			.session-body th, .session-body td {
				padding: 0.4rem 0.6rem;
				border-bottom: 1px solid #eee;
				text-align: left;
				word-wrap: break-word;
			}
			.session-body th {
				font-weight: 600;
				font-size: 0.8rem;
				color: #666;
			}

			@media (max-width: 600px) {
				.phase-timeline {
					padding-left: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<p class="session-date">{date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
				<h1>{title}</h1>

				<div class="phase-timeline">
					{phases.map(phase => (
						<div class="phase-item">
							<div class="phase-header">
								<a href={phase.href} class="phase-label">{phase.name}</a>
								<span class="phase-hint">{phase.hint}</span>
							</div>
							<div class="phase-text">{phase.text}</div>
						</div>
					))}
				</div>

				<div class="session-body">
					<Content />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			// Add copy buttons to all code blocks
			document.querySelectorAll('.session-body pre').forEach(pre => {
				const btn = document.createElement('button');
				btn.className = 'copy-btn';
				btn.textContent = 'copy';
				btn.addEventListener('click', async () => {
					const code = pre.querySelector('code')?.textContent || pre.textContent;
					await navigator.clipboard.writeText(code.trim());
					btn.textContent = 'copied';
					btn.classList.add('copied');
					setTimeout(() => {
						btn.textContent = 'copy';
						btn.classList.remove('copied');
					}, 2000);
				});
				pre.style.position = 'relative';
				pre.appendChild(btn);
			});
		</script>
	</body>
</html>
