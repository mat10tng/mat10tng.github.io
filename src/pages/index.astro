---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			.hero h1 { font-size: 1.2rem; margin-bottom: 0.25rem; }
			.hero .intro {
				color: #666; font-size: 0.9rem; line-height: 1.6; margin-bottom: 2.5rem;
			}
			.layer { margin-bottom: 2.5rem; }
			.layer-label {
				font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
				letter-spacing: 0.1em; color: #999; margin-bottom: 1rem;
			}
			.diagram-wrap { overflow-x: auto; margin-bottom: 0.75rem; }
			.diagram-wrap svg { display: block; max-width: 100%; height: auto; }
			.diagram-wrap svg text { font-family: system-ui, -apple-system, sans-serif; }
			.diagram-wrap svg a text { fill: #333; }
			.diagram-wrap svg a:hover text { fill: #2563eb; }
			.diagram-wrap svg a rect { transition: stroke 150ms; }
			.diagram-wrap svg a:hover rect { stroke: #2563eb; }
			.layer-desc {
				font-size: 0.88rem; color: #555; line-height: 1.6; max-width: 640px;
			}
			.layer-desc a { color: #2563eb; text-decoration: none; }
			.layer-desc a:hover { text-decoration: underline; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>how I work with AI</h1>
				<p class="intro">
					I build software with Claude every day. over time I built a system around the work —
					four parts that talk to each other. this site documents how that system works and evolves.
				</p>

				<!-- THE ARCHITECTURE -->
				<div class="layer">
					<div class="layer-label">the architecture</div>
					<div class="diagram-wrap">
						<svg viewBox="0 0 560 230" width="560">
							<!-- human -->
							<rect x="420" y="2" width="130" height="36" rx="18" fill="none" stroke="#333" stroke-width="1.2" stroke-dasharray="4 2"/>
							<text x="485" y="24" text-anchor="middle" font-size="11" fill="#333">me — I direct</text>

							<!-- arrow: human → worker -->
							<line x1="485" y1="42" x2="485" y2="62" stroke="#bbb" stroke-width="1"/>
							<polygon points="482,60 485,66 488,60" fill="#bbb"/>

							<!-- the brain -->
							<rect x="4" y="68" width="146" height="96" rx="8" fill="none" stroke="#2563eb" stroke-width="1.4"/>
							<text x="77" y="88" text-anchor="middle" font-size="12" font-weight="600" fill="#2563eb">the brain</text>
							<text x="77" y="101" text-anchor="middle" font-size="8" fill="#888">all knowledge lives here</text>
							<!-- project structure -->
							<rect x="14" y="110" width="60" height="18" rx="3" fill="none" stroke="#ddd" stroke-width="0.6"/>
							<text x="44" y="122" text-anchor="middle" font-size="7" fill="#aaa">project A</text>
							<rect x="82" y="110" width="60" height="18" rx="3" fill="none" stroke="#ddd" stroke-width="0.6"/>
							<text x="112" y="122" text-anchor="middle" font-size="7" fill="#aaa">project B</text>
							<rect x="38" y="134" width="70" height="18" rx="3" fill="none" stroke="#2563eb" stroke-width="0.6" stroke-dasharray="2 1"/>
							<text x="73" y="146" text-anchor="middle" font-size="7" fill="#2563eb">global rules</text>
							<!-- graduation arrow -->
							<line x1="44" y1="128" x2="55" y2="134" stroke="#ccc" stroke-width="0.5"/>
							<line x1="112" y1="128" x2="90" y2="134" stroke="#ccc" stroke-width="0.5"/>

							<!-- the bridge -->
							<rect x="207" y="68" width="146" height="96" rx="8" fill="none" stroke="#333" stroke-width="1.2"/>
							<text x="280" y="88" text-anchor="middle" font-size="12" font-weight="600" fill="#333">the bridge</text>
							<text x="280" y="101" text-anchor="middle" font-size="8" fill="#888">reads, writes, enforces</text>
							<text x="222" y="118" font-size="7.5" fill="#aaa">search</text>
							<text x="222" y="130" font-size="7.5" fill="#aaa">capture</text>
							<text x="222" y="142" font-size="7.5" fill="#aaa">brief</text>
							<text x="295" y="118" font-size="7.5" fill="#aaa">measure</text>
							<text x="295" y="130" font-size="7.5" fill="#aaa">compact</text>
							<text x="295" y="142" font-size="7.5" fill="#aaa">archive</text>
							<!-- scheduled indicator -->
							<rect x="232" y="150" width="96" height="12" rx="2" fill="none" stroke="#ddd" stroke-width="0.5"/>
							<text x="280" y="159" text-anchor="middle" font-size="6.5" fill="#999">+ scheduled tasks</text>

							<!-- the worker -->
							<rect x="410" y="68" width="146" height="96" rx="8" fill="none" stroke="#333" stroke-width="1.2"/>
							<text x="483" y="88" text-anchor="middle" font-size="12" font-weight="600" fill="#333">the worker</text>
							<text x="483" y="101" text-anchor="middle" font-size="8" fill="#888">builds, fixes, ships</text>
							<text x="425" y="118" font-size="7.5" fill="#aaa">brainstorm</text>
							<text x="425" y="130" font-size="7.5" fill="#aaa">debug</text>
							<text x="425" y="142" font-size="7.5" fill="#aaa">review</text>
							<text x="505" y="118" font-size="7.5" fill="#aaa">implement</text>
							<text x="505" y="130" font-size="7.5" fill="#aaa">test</text>
							<text x="505" y="142" font-size="7.5" fill="#aaa">deploy</text>

							<!-- arrows: brain ↔ bridge -->
							<line x1="154" y1="106" x2="203" y2="106" stroke="#bbb" stroke-width="1"/>
							<polygon points="201,103 207,106 201,109" fill="#bbb"/>
							<line x1="203" y1="126" x2="154" y2="126" stroke="#bbb" stroke-width="1"/>
							<polygon points="156,123 150,126 156,129" fill="#bbb"/>

							<!-- arrows: bridge ↔ worker -->
							<line x1="357" y1="106" x2="406" y2="106" stroke="#bbb" stroke-width="1"/>
							<polygon points="404,103 410,106 404,109" fill="#bbb"/>
							<line x1="406" y1="126" x2="357" y2="126" stroke="#bbb" stroke-width="1"/>
							<polygon points="359,123 353,126 359,129" fill="#bbb"/>

							<!-- arrow labels -->
							<text x="178" y="100" text-anchor="middle" font-size="6.5" fill="#aaa">recall</text>
							<text x="178" y="137" text-anchor="middle" font-size="6.5" fill="#aaa">store</text>
							<text x="381" y="100" text-anchor="middle" font-size="6.5" fill="#aaa">context</text>
							<text x="381" y="137" text-anchor="middle" font-size="6.5" fill="#aaa">results</text>

							<!-- feedback loop: bottom to top -->
							<text x="280" y="188" text-anchor="middle" font-size="8" fill="#999">↻ improvements feed back into all three</text>

							<!-- bottom stats -->
							<text x="77" y="210" text-anchor="middle" font-size="7.5" fill="#999">1400+ notes</text>
							<text x="77" y="222" text-anchor="middle" font-size="7.5" fill="#999">projects → global</text>
							<text x="280" y="210" text-anchor="middle" font-size="7.5" fill="#999">enforces rules</text>
							<text x="280" y="222" text-anchor="middle" font-size="7.5" fill="#999">runs between sessions</text>
							<text x="483" y="210" text-anchor="middle" font-size="7.5" fill="#999">Claude · skills</text>
							<text x="483" y="222" text-anchor="middle" font-size="7.5" fill="#999">directed by human</text>
						</svg>
					</div>
					<p class="layer-desc">
						I direct the worker. the worker asks the bridge for context. the bridge loads from the brain.
						results flow back. between sessions, the bridge runs scheduled tasks — compaction, cleanup, health checks.
						knowledge graduates from projects to global rules. improvements feed back into all three parts.
					</p>
				</div>

				<!-- EACH SESSION -->
				<div class="layer">
					<div class="layer-label">each session</div>
					<div class="diagram-wrap">
						<svg viewBox="0 0 560 58" width="560">
							<rect x="0" y="16" width="84" height="26" rx="6" fill="none" stroke="#333" stroke-width="1.1"/>
							<text x="42" y="32" text-anchor="middle" font-size="10">load memory</text>
							<line x1="88" y1="29" x2="110" y2="29" stroke="#bbb" stroke-width="1"/>
							<polygon points="108,26 114,29 108,32" fill="#bbb"/>

							<rect x="116" y="16" width="74" height="26" rx="6" fill="none" stroke="#333" stroke-width="1.1"/>
							<text x="153" y="32" text-anchor="middle" font-size="10">pick skill</text>
							<line x1="194" y1="29" x2="216" y2="29" stroke="#bbb" stroke-width="1"/>
							<polygon points="214,26 220,29 214,32" fill="#bbb"/>

							<rect x="222" y="16" width="60" height="26" rx="6" fill="none" stroke="#333" stroke-width="1.1"/>
							<text x="252" y="32" text-anchor="middle" font-size="10">work</text>
							<line x1="286" y1="29" x2="308" y2="29" stroke="#bbb" stroke-width="1"/>
							<polygon points="306,26 312,29 306,32" fill="#bbb"/>

							<rect x="314" y="16" width="72" height="26" rx="6" fill="none" stroke="#333" stroke-width="1.1"/>
							<text x="350" y="32" text-anchor="middle" font-size="10">capture</text>
							<line x1="390" y1="29" x2="412" y2="29" stroke="#bbb" stroke-width="1"/>
							<polygon points="410,26 416,29 410,32" fill="#bbb"/>

							<rect x="418" y="16" width="80" height="26" rx="6" fill="none" stroke="#2563eb" stroke-width="1.1"/>
							<text x="458" y="32" text-anchor="middle" font-size="10" fill="#2563eb">→ brain</text>

							<text x="42" y="9" text-anchor="middle" font-size="7" fill="#999">recall</text>
							<text x="153" y="9" text-anchor="middle" font-size="7" fill="#999">approach</text>
							<text x="252" y="9" text-anchor="middle" font-size="7" fill="#999">build</text>
							<text x="350" y="9" text-anchor="middle" font-size="7" fill="#999">record</text>
							<text x="458" y="9" text-anchor="middle" font-size="7" fill="#999">stored</text>
						</svg>
					</div>
					<p class="layer-desc">
						every session starts by loading what previous sessions learned. a skill shapes the approach. everything gets captured. <a href="/blog">sessions →</a>
					</p>
				</div>

				<!-- IMPROVING THE WORK -->
				<div class="layer">
					<div class="layer-label">improving how we work</div>
					<div class="diagram-wrap">
						<svg viewBox="0 0 500 58" width="500">
							<rect x="0" y="16" width="72" height="26" rx="6" fill="none" stroke="#333" stroke-width="1.1"/>
							<text x="36" y="32" text-anchor="middle" font-size="10">captures</text>
							<line x1="76" y1="29" x2="98" y2="29" stroke="#bbb" stroke-width="1"/>
							<polygon points="96,26 102,29 96,32" fill="#bbb"/>

							<rect x="104" y="16" width="60" height="26" rx="6" fill="none" stroke="#333" stroke-width="1.1"/>
							<text x="134" y="32" text-anchor="middle" font-size="10">distill</text>
							<line x1="168" y1="29" x2="190" y2="29" stroke="#bbb" stroke-width="1"/>
							<polygon points="188,26 194,29 188,32" fill="#bbb"/>

							<rect x="196" y="16" width="66" height="26" rx="6" fill="none" stroke="#333" stroke-width="1.1"/>
							<text x="229" y="32" text-anchor="middle" font-size="10">lessons</text>
							<line x1="266" y1="29" x2="288" y2="29" stroke="#bbb" stroke-width="1"/>
							<polygon points="286,26 292,29 286,32" fill="#bbb"/>

							<rect x="294" y="16" width="54" height="26" rx="6" fill="none" stroke="#333" stroke-width="1.1"/>
							<text x="321" y="32" text-anchor="middle" font-size="10">rules</text>
							<line x1="352" y1="29" x2="374" y2="29" stroke="#bbb" stroke-width="1"/>
							<polygon points="372,26 378,29 372,32" fill="#bbb"/>

							<a href="/history">
								<rect x="380" y="16" width="74" height="26" rx="6" fill="none" stroke="#2563eb" stroke-width="1.1"/>
								<text x="417" y="32" text-anchor="middle" font-size="10" fill="#2563eb">measure</text>
							</a>

							<text x="36" y="9" text-anchor="middle" font-size="7" fill="#999">raw</text>
							<text x="134" y="9" text-anchor="middle" font-size="7" fill="#999">compress</text>
							<text x="229" y="9" text-anchor="middle" font-size="7" fill="#999">reusable</text>
							<text x="321" y="9" text-anchor="middle" font-size="7" fill="#999">permanent</text>
							<text x="417" y="9" text-anchor="middle" font-size="7" fill="#999">validated</text>
						</svg>
					</div>
					<p class="layer-desc">
						captures get distilled into lessons. lessons that keep being useful become rules. rules are measured. this is how the work gets better. <a href="/blog">sessions →</a>
					</p>
				</div>

				<!-- IMPROVING THE SYSTEM -->
				<div class="layer">
					<div class="layer-label">improving the system itself</div>
					<div class="diagram-wrap">
						<svg viewBox="0 0 480 80" width="480">
							<text x="8" y="16" font-size="9" fill="#666">the same review process also changes the system:</text>

							<a href="/history">
								<rect x="8" y="28" width="140" height="26" rx="6" fill="none" stroke="#2563eb" stroke-width="1.1"/>
								<text x="78" y="44" text-anchor="middle" font-size="10" fill="#2563eb">reshape the brain</text>
							</a>
							<a href="/history">
								<rect x="168" y="28" width="146" height="26" rx="6" fill="none" stroke="#2563eb" stroke-width="1.1"/>
								<text x="241" y="44" text-anchor="middle" font-size="10" fill="#2563eb">upgrade the bridge</text>
							</a>
							<a href="/history">
								<rect x="334" y="28" width="136" height="26" rx="6" fill="none" stroke="#2563eb" stroke-width="1.1"/>
								<text x="402" y="44" text-anchor="middle" font-size="10" fill="#2563eb">refine the skills</text>
							</a>

							<text x="78" y="68" text-anchor="middle" font-size="7" fill="#aaa">new types · better structure</text>
							<text x="241" y="68" text-anchor="middle" font-size="7" fill="#aaa">new tools · better surfacing</text>
							<text x="402" y="68" text-anchor="middle" font-size="7" fill="#aaa">new skills · sharper rules</text>
						</svg>
					</div>
					<p class="layer-desc">
						the system improves the system. every part — the brain, the bridge, the worker — gets reshaped by what we learn. <a href="/history">evolution →</a>
					</p>
				</div>

			</section>
		</main>
		<Footer />
	</body>
</html>
