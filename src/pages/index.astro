---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import historyData from '../data/history.json';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				max-width: 900px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			.hero h1 { font-size: 1.4rem; margin-bottom: 0.5rem; }
			.hero .intro {
				color: #666; font-size: 1rem; line-height: 1.6; margin-bottom: 3rem;
			}
			.layer { margin-bottom: 4rem; }
			.layer-label {
				font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
				letter-spacing: 0.12em; color: #999; margin-bottom: 1.5rem;
			}
			.diagram-wrap { 
				overflow-x: auto; 
				margin-bottom: 2rem;
				background: #fff;
				border-radius: 8px;
			}
			.diagram-wrap svg { 
				display: block; 
				width: 100%; 
				max-width: 800px; 
				height: auto; 
				margin: 0 auto;
			}
			.diagram-wrap svg text { font-family: system-ui, -apple-system, sans-serif; }
			.layer-desc {
				font-size: 1rem; color: #444; line-height: 1.7; max-width: 720px;
				margin-top: 1rem;
			}
			.layer-desc a { color: #2563eb; text-decoration: none; font-weight: 500; }
			.layer-desc a:hover { text-decoration: underline; }

			.path-grid {
				display: flex;
				flex-direction: column;
				gap: 1.25rem;
				margin-top: 1.5rem;
			}
			.path-link {
				text-decoration: none;
				display: flex;
				align-items: baseline;
				gap: 1rem;
				group;
			}
			.path-step {
				font-size: 0.75rem;
				font-weight: 700;
				color: #999;
				font-family: monospace;
				width: 2rem;
			}
			.path-content {
				display: flex;
				flex-direction: column;
			}
			.path-title {
				font-size: 1.05rem;
				font-weight: 600;
				color: #2563eb;
			}
			.path-link:hover .path-title {
				text-decoration: underline;
			}
			.path-desc {
				font-size: 0.9rem;
				color: #666;
				line-height: 1.5;
				margin: 0.15rem 0 0 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>How I work with AI</h1>
				<p class="intro">
					I build software with AI every day. Over time, I built a system around the work — 
					four parts that coordinate to maintain context and improve standards.
				</p>

				<!-- THE ARCHITECTURE -->
				<div class="layer">
					<div class="layer-label">System Architecture</div>
					<div class="diagram-wrap">
						<svg viewBox="0 0 560 230" width="800">
							<!-- human -->
							<a href="https://www.linkedin.com/in/tuan-nguyen-it-ot/" target="_blank">
								<rect x="405" y="2" width="150" height="40" rx="20" fill="none" stroke="#333" stroke-width="1.5" stroke-dasharray="4 2"/>
								<text x="480" y="22" text-anchor="middle" font-size="12" font-weight="600" fill="#333">Human Architect</text>
								<text x="480" y="34" text-anchor="middle" font-size="8" fill="#888">decision maker</text>
							</a>

							<!-- arrow: human → worker -->
							<line x1="485" y1="42" x2="485" y2="62" stroke="#bbb" stroke-width="1.5"/>
							<polygon points="481,60 485,68 489,60" fill="#bbb"/>

							<!-- the vault -->
							<rect x="4" y="68" width="156" height="106" rx="8" fill="none" stroke="#2563eb" stroke-width="2"/>
							<text x="82" y="90" text-anchor="middle" font-size="14" font-weight="700" fill="#2563eb">the vault</text>
							<text x="82" y="105" text-anchor="middle" font-size="9" fill="#888">persistent knowledge</text>
							
							<!-- project structure -->
							<rect x="14" y="115" width="64" height="20" rx="3" fill="none" stroke="#ddd" stroke-width="1"/>
							<text x="46" y="128" text-anchor="middle" font-size="9" fill="#777">project A</text>
							<rect x="86" y="115" width="64" height="20" rx="3" fill="none" stroke="#ddd" stroke-width="1"/>
							<text x="118" y="128" text-anchor="middle" font-size="9" fill="#777">project B</text>
							<rect x="42" y="142" width="80" height="20" rx="3" fill="none" stroke="#2563eb" stroke-width="1" stroke-dasharray="2 1"/>
							<text x="82" y="155" text-anchor="middle" font-size="9" font-weight="600" fill="#2563eb">global rules</text>
							
							<!-- graduation arrow -->
							<line x1="46" y1="135" x2="62" y2="142" stroke="#ccc" stroke-width="0.8"/>
							<line x1="118" y1="135" x2="102" y2="142" stroke="#ccc" stroke-width="0.8"/>

							<!-- the bridge -->
							<rect x="202" y="68" width="156" height="106" rx="8" fill="none" stroke="#333" stroke-width="1.5"/>
							<text x="280" y="90" text-anchor="middle" font-size="14" font-weight="700" fill="#333">the bridge</text>
							<text x="280" y="105" text-anchor="middle" font-size="9" fill="#888">rules & context</text>
							
							<text x="220" y="125" font-size="10" fill="#666">search</text>
							<text x="220" y="140" font-size="10" fill="#666">capture</text>
							<text x="220" y="155" font-size="10" fill="#666">brief</text>
							<text x="300" y="125" font-size="10" fill="#666">measure</text>
							<text x="300" y="140" font-size="10" fill="#666">compact</text>
							<text x="300" y="155" font-size="10" fill="#666">archive</text>

							<!-- the worker -->
							<rect x="400" y="68" width="156" height="106" rx="8" fill="none" stroke="#333" stroke-width="1.5"/>
							<text x="478" y="90" text-anchor="middle" font-size="14" font-weight="700" fill="#333">the worker</text>
							<text x="478" y="105" text-anchor="middle" font-size="9" fill="#888">execution (Model)</text>
							
							<text x="418" y="125" font-size="10" fill="#666">brainstorm</text>
							<text x="418" y="140" font-size="10" fill="#666">debug</text>
							<text x="418" y="155" font-size="10" fill="#666">review</text>
							<text x="500" y="125" font-size="10" fill="#666">implement</text>
							<text x="500" y="140" font-size="10" fill="#666">test</text>
							<text x="500" y="155" font-size="10" fill="#666">deploy</text>

							<!-- arrows: vault ↔ bridge -->
							<line x1="160" y1="110" x2="202" y2="110" stroke="#bbb" stroke-width="1.5"/>
							<polygon points="198,107 206,110 198,113" fill="#bbb"/>
							<line x1="202" y1="130" x2="160" y2="130" stroke="#bbb" stroke-width="1.5"/>
							<polygon points="164,127 156,130 164,133" fill="#bbb"/>

							<!-- arrows: bridge ↔ worker -->
							<line x1="358" y1="110" x2="400" y2="110" stroke="#bbb" stroke-width="1.5"/>
							<polygon points="396,107 404,110 396,113" fill="#bbb"/>
							<line x1="400" y1="130" x2="358" y2="130" stroke="#bbb" stroke-width="1.5"/>
							<polygon points="362,127 354,130 362,133" fill="#bbb"/>

							<!-- arrow labels -->
							<text x="181" y="105" text-anchor="middle" font-size="8" font-weight="500" fill="#999">recall</text>
							<text x="181" y="142" text-anchor="middle" font-size="8" font-weight="500" fill="#999">store</text>
							<text x="379" y="105" text-anchor="middle" font-size="8" font-weight="500" fill="#999">context</text>
							<text x="379" y="142" text-anchor="middle" font-size="8" font-weight="500" fill="#999">results</text>

							<!-- feedback loop -->
							<text x="280" y="195" text-anchor="middle" font-size="10" font-weight="500" fill="#888">↻ improvements cycle back into the vault</text>

							<!-- bottom stats -->
							<text x="82" y="215" text-anchor="middle" font-size="9" font-weight="600" fill="#999">{historyData.current.total_notes}+ notes</text>
							<text x="280" y="215" text-anchor="middle" font-size="9" font-weight="600" fill="#999">automated maintenance</text>
							<text x="478" y="215" text-anchor="middle" font-size="9" font-weight="600" fill="#999">human-directed</text>
						</svg>
					</div>
					<p class="layer-desc">
						A system for persistent learning. The model uses the knowledge base to maintain project context and follow global standards. Between sessions, automated tasks handle maintenance, cleanup, and the distillation of new lessons.
					</p>
				</div>

				<!-- START HERE -->
				<div class="layer">
					<div class="layer-header" style="display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1.5rem;">
						<div class="layer-label" style="margin-bottom: 0;">Implementation Path</div>
						<div style="font-size: 0.7rem; color: #aaa; text-transform: uppercase; letter-spacing: 0.05em;">Overview: Vault → Bridge → Worker</div>
					</div>
					<div class="path-grid">
						<a href="/blog/2026-04-23-prompt-to-system" class="path-link">
							<div class="path-step">01</div>
							<div class="path-content">
								<div class="path-title">prompt -> a system</div>
								<p class="path-desc">Why you need boundaries and structure, not better adjectives.</p>
							</div>
						</a>
						<a href="/blog/2026-04-23-files-to-vault" class="path-link">
							<div class="path-step">02</div>
							<div class="path-content">
								<div class="path-title">files -> a vault</div>
								<p class="path-desc">Setting up a zero-code file system for project context.</p>
							</div>
						</a>
						<a href="/blog/2026-04-08-logs-to-rules" class="path-link">
							<div class="path-step">03</div>
							<div class="path-content">
								<div class="path-title">logs -> rules</div>
								<p class="path-desc">How to graduate daily session logs into permanent logic.</p>
							</div>
						</a>
						<a href="/blog/2026-04-24-manual-to-automated" class="path-link">
							<div class="path-step">04</div>
							<div class="path-content">
								<div class="path-title">manual -> automated</div>
								<p class="path-desc">Connecting your vault directly to an AI assistant via MCP.</p>
							</div>
						</a>
					</div>
				</div>

				<!-- CORE CONCEPTS -->
				<div class="layer">
					<div class="layer-label">Core Concepts</div>
					<div class="path-grid">
						<a href="/blog/2026-04-17-the-wrong-owner" class="path-link">
							<div class="path-step">→</div>
							<div class="path-content">
								<div class="path-title">Transferring Responsibility</div>
								<p class="path-desc">Moving logic from probabilistic AI to deterministic code.</p>
							</div>
						</a>
						<a href="/blog/2026-03-20-three-levers" class="path-link">
							<div class="path-step">→</div>
							<div class="path-content">
								<div class="path-title">The Three Levers</div>
								<p class="path-desc">A diagnostic framework for debugging agent behavior.</p>
							</div>
						</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
