---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				min-height: 60vh;
				padding: 2rem 1rem;
			}
			.ascii-flow {
				font-family: 'Courier New', Courier, monospace;
				font-size: 0.85rem;
				line-height: 1.4;
				white-space: pre;
				color: var(--text-color, #333);
				user-select: none;
			}
			.ascii-flow a {
				color: inherit;
				text-decoration: none;
				transition: color 150ms ease;
			}
			.ascii-flow a:hover {
				color: var(--accent-color, #2563eb);
			}
			.ascii-flow .node {
				font-weight: 700;
			}
			.ascii-flow .link-node {
				font-weight: 700;
				border-bottom: 1px dashed currentColor;
			}
			.tagline {
				margin-top: 2rem;
				font-size: 0.9rem;
				color: var(--muted-color, #666);
				text-align: center;
				max-width: 420px;
				line-height: 1.6;
			}

			@media (max-width: 600px) {
				.ascii-flow {
					font-size: 0.65rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="ascii-flow" role="img" aria-label="workflow loop: work, capture, review, improve, measure">
{`                 ┌──────────────────────────┐
                 │                          │
                 ▼                          │
            ┌─────────┐              ┌─────┴─────┐
            │  `}<span class="node">work</span>{`   │─────────────▶│  `}<a href="/blog" class="link-node">capture</a>{`  │
            └─────────┘              └─────┬─────┘
                 ▲                         │
                 │                         ▼
            ┌────┴────┐              ┌───────────┐
            │ `}<a href="/history" class="link-node">measure</a>{` │◀─────────────│  `}<span class="node">review</span>{`   │
            └─────────┘              └─────┬─────┘
                 ▲                         │
                 │                         ▼
                 │                    ┌─────────┐
                 └────────────────────│  `}<span class="node">improve</span>{` │
                                     └─────────┘`}
				</div>
				<p class="tagline">
					work. capture everything. review what happened.<br>
					improve the system. measure whether it worked.<br>
					repeat.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
