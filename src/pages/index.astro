---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				min-height: 70vh;
				padding: 2rem 1rem;
			}
			.two-loops {
				display: flex;
				gap: 3rem;
				align-items: flex-start;
				flex-wrap: wrap;
				justify-content: center;
			}
			.loop-column {
				display: flex;
				flex-direction: column;
				align-items: center;
			}
			.loop-label {
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--muted-color, #666);
				margin-bottom: 1rem;
			}
			.ascii-flow {
				font-family: 'Courier New', Courier, monospace;
				font-size: 0.8rem;
				line-height: 1.4;
				white-space: pre;
				color: var(--text-color, #333);
				user-select: none;
			}
			.ascii-flow a {
				color: inherit;
				text-decoration: none;
				transition: color 150ms ease;
			}
			.ascii-flow a:hover {
				color: var(--accent-color, #2563eb);
			}
			.ascii-flow .node {
				font-weight: 700;
			}
			.ascii-flow .link-node {
				font-weight: 700;
				border-bottom: 1px dashed currentColor;
			}
			.bridge {
				font-family: 'Courier New', Courier, monospace;
				font-size: 0.8rem;
				color: var(--muted-color, #999);
				align-self: center;
				margin-top: 2rem;
				white-space: pre;
			}
			.tagline {
				margin-top: 2rem;
				font-size: 0.9rem;
				color: var(--muted-color, #666);
				text-align: center;
				max-width: 520px;
				line-height: 1.6;
			}

			@media (max-width: 700px) {
				.ascii-flow {
					font-size: 0.6rem;
				}
				.two-loops {
					gap: 1.5rem;
				}
				.bridge {
					font-size: 0.6rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="two-loops">
					<div class="loop-column">
						<div class="loop-label">each session</div>
						<div class="ascii-flow" role="img" aria-label="session loop: work, capture, review, improve">
{`     в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
     в”Ӯ                в”Ӯ
     в–ј                в”Ӯ
 в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ     в”Ңв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”җ
 в”Ӯ  `}<span class="node">work</span>{`  в”Ӯв”Җв”Җв”Җв”Җв–¶в”Ӯ `}<a href="/blog" class="link-node">capture</a>{` в”Ӯ
 в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ     в””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”ҳ
     в–І               в”Ӯ
     в”Ӯ               в–ј
 в”Ңв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”җ    в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
 в”Ӯ`}<span class="node">improve</span>{` в”Ӯв—Җв”Җв”Җв”Җв”Ӯ  `}<span class="node">review</span>{`  в”Ӯ
 в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ    в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ`}
						</div>
					</div>
					<div class="loop-column">
						<div class="loop-label">across sessions</div>
						<div class="ascii-flow" role="img" aria-label="system loop: lessons become rules, measured over time">
{`  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
  в”Ӯ                  в”Ӯ
  в–ј                  в”Ӯ
 в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ   в”Ңв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”җ
 в”Ӯ lessons в”Ӯв”Җв”Җв–¶в”Ӯ   rules  в”Ӯ
 в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ   в””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”ҳ
                    в”Ӯ
                    в–ј
              в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
              в”Ӯ `}<a href="/history" class="link-node">measure</a>{`  в”Ӯ
              в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ`}
						</div>
					</div>
				</div>
				<div class="bridge">
{`         capture в”Җв”Җв”Җв”Җв”Җв”Җв–¶ lessons`}
				</div>
				<p class="tagline">
					each session: work, capture, review, improve.<br>
					across sessions: lessons become rules. rules get measured.<br>
					the system gets better. <a href="/system">here's how</a>.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
