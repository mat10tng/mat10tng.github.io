---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import historyData from '../data/history.json';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				margin-bottom: 4rem;
			}
			.hero h1 { font-size: 1.75rem; margin-bottom: 1rem; }
			.hero .intro {
				color: var(--gray-dark); font-size: 1.1rem; line-height: 1.6;
                font-style: italic;
			}
			.layer { margin-bottom: 4rem; }
			.layer-label {
				font-family: var(--font-sans);
				font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
				letter-spacing: 0.1em; color: var(--gray); margin-bottom: 1.5rem;
                border-bottom: 1px solid var(--gray-light);
                padding-bottom: 0.5rem;
			}
			.diagram-wrap { 
				overflow-x: auto; 
				margin: 2rem 0;
				background: #fff;
			}
			.diagram-wrap svg { 
				display: block; 
				width: 100%; 
				max-width: 800px; 
				height: auto; 
				margin: 0 auto;
			}
			.diagram-wrap svg text { font-family: var(--font-sans); }
			.layer-desc {
				font-size: 1rem; color: var(--black); line-height: 1.7; max-width: 720px;
				margin-top: 1rem;
			}
			.layer-desc a { color: var(--accent); text-decoration: underline; }

            /* Technical Link List */
			.path-grid {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				margin-top: 1.5rem;
			}
			.path-link {
				text-decoration: none;
				display: flex;
				align-items: baseline;
				gap: 1rem;
			}
			.path-step {
				font-size: 0.85rem;
				font-weight: 700;
				color: var(--gray);
				font-family: ui-monospace, monospace;
				width: 2rem;
			}
			.path-content {
				display: flex;
				flex-direction: column;
			}
			.path-title {
				font-size: 1.1rem;
				font-weight: 700;
				color: var(--accent);
                text-decoration: underline;
			}
			.path-link:hover .path-title {
				color: var(--black);
			}
			.path-desc {
				font-size: 0.95rem;
				color: var(--gray-dark);
				line-height: 1.5;
				margin: 0.25rem 0 0 0;
			}

            /* Workflow SVG styles */
            .workflow-svg-link:hover {
                fill: var(--accent) !important;
                font-weight: 700;
                cursor: pointer;
            }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Working with AI assistants</h1>
				<p class="intro">
					Notes on persistent memory, architectural boundaries, and automated engineering standards.
				</p>

				<div class="layer">
					<div class="layer-label">System Architecture</div>
					<div class="diagram-wrap">
						<svg viewBox="0 0 560 230" width="800">
							<!-- Architect -->
							<a href="https://www.linkedin.com/in/tuan-nguyen-it-ot/" target="_blank">
                                <circle cx="480" cy="12" r="6" fill="none" stroke="#333" stroke-width="1.5"/>
                                <path d="M 468 32 Q 480 20 492 32" fill="none" stroke="#333" stroke-width="1.5"/>
								<text x="480" y="44" text-anchor="middle" font-size="11" font-weight="600" fill="#333">Architect</text>
							</a>

							<!-- arrow: human → LLM -->
							<line x1="480" y1="48" x2="480" y2="62" stroke="#bbb" stroke-width="1.5"/>
							<polygon points="476,60 480,68 484,60" fill="#bbb"/>

							<!-- Memory -->
							<rect x="4" y="68" width="156" height="106" rx="4" fill="none" stroke="#2563eb" stroke-width="1.5"/>
							<text x="82" y="90" text-anchor="middle" font-size="13" font-weight="700" fill="#2563eb">Memory</text>
							
							<!-- folder representation -->
							<rect x="14" y="105" width="60" height="18" rx="2" fill="none" stroke="#ddd" stroke-width="1"/>
							<text x="44" y="117" text-anchor="middle" font-size="8" fill="#777">/sessions</text>
							<rect x="82" y="105" width="60" height="18" rx="2" fill="none" stroke="#ddd" stroke-width="1"/>
							<text x="112" y="117" text-anchor="middle" font-size="8" fill="#777">/lessons</text>
							<rect x="42" y="128" width="80" height="18" rx="2" fill="none" stroke="#2563eb" stroke-width="1" stroke-dasharray="2 1"/>
							<text x="82" y="140" text-anchor="middle" font-size="8" font-weight="600" fill="#2563eb">global rules</text>

							<!-- Interface -->
							<rect x="202" y="68" width="156" height="106" rx="4" fill="none" stroke="#333" stroke-width="1.2"/>
							<text x="280" y="90" text-anchor="middle" font-size="13" font-weight="700" fill="#333">Interface</text>
							
							<text x="220" y="115" font-size="9" fill="#666">search</text>
							<text x="220" y="130" font-size="9" fill="#666">capture</text>
							<text x="300" y="115" font-size="9" fill="#666">measure</text>
							<text x="300" y="130" font-size="9" fill="#666">compact</text>

							<!-- LLM -->
							<rect x="400" y="68" width="156" height="126" rx="4" fill="none" stroke="#333" stroke-width="1.2"/>
							<text x="478" y="88" text-anchor="middle" font-size="13" font-weight="700" fill="#333">LLM</text>
                            
                            <!-- System Rules inside LLM -->
                            <a href="/blog/2026-04-23-prompt-to-self-curating#3-system-rules">
							    <rect x="410" y="100" width="136" height="18" rx="2" fill="#f9fafb" stroke="#2563eb" stroke-width="0.8" stroke-dasharray="2 1"/>
							    <text x="478" y="112" text-anchor="middle" font-size="8.5" font-weight="600" fill="#2563eb">System Rules</text>
                            </a>
							
                            <!-- Workflow links inside LLM -->
                            <a href="/blog/2026-04-25-brainstorm"><text x="418" y="132" font-size="9.5" fill="#666" class="workflow-svg-link">brainstorm</text></a>
							<a href="/blog/2026-04-27-debug"><text x="418" y="145" font-size="9.5" fill="#666" class="workflow-svg-link">debug</text></a>
							<a href="/blog/2026-04-29-review"><text x="418" y="158" font-size="9.5" fill="#666" class="workflow-svg-link">review</text></a>
							<a href="/blog/2026-04-26-implement"><text x="500" y="132" font-size="9.5" fill="#666" class="workflow-svg-link">implement</text></a>
							<a href="/blog/2026-04-28-test"><text x="500" y="145" font-size="9.5" fill="#666" class="workflow-svg-link">test</text></a>
							<a href="/blog/2026-04-30-deploy"><text x="500" y="158" font-size="9.5" fill="#666" class="workflow-svg-link">deploy</text></a>

							<!-- arrows -->
							<line x1="160" y1="110" x2="202" y2="110" stroke="#bbb" stroke-width="1.2"/>
							<line x1="358" y1="110" x2="400" y2="110" stroke="#bbb" stroke-width="1.2"/>
							<line x1="280" y1="48" x2="280" y2="110" stroke="#bbb" stroke-width="1.2"/>
							<polygon points="276,108 280,116 284,108" fill="#bbb"/>

							<!-- labels -->
							<text x="181" y="105" text-anchor="middle" font-size="8" fill="#999">recall</text>
							<text x="379" y="105" text-anchor="middle" font-size="8" fill="#999">context</text>
							<text x="280" y="205" text-anchor="middle" font-size="9" font-style="italic" fill="#888">↻ improvements cycle back into Memory</text>
						</svg>
					</div>
					<p class="layer-desc">
						The LLM uses an interface to maintain project context and follow global standards. Between sessions, automated tasks handle maintenance, cleanup, and distillation of new engineering logic.
					</p>
				</div>

				<div class="layer">
					<div class="layer-label">Implementation Path</div>
					<div class="path-grid">
						<a href="/blog/2026-04-23-prompt-to-self-curating" class="path-link">
							<div class="path-step">01</div>
							<div class="path-content">
								<div class="path-title">prompt -> persistent memory</div>
								<p class="path-desc">Defining foundational boundaries and a self-curating local context system.</p>
							</div>
						</a>
						<a href="/blog/2026-04-24-data-driven-improvement" class="path-link">
							<div class="path-step">02</div>
							<div class="path-content">
								<div class="path-title">[draft] manual -> automated data</div>
								<p class="path-desc">Using MCP to measure success and scale the self-improving loop.</p>
							</div>
						</a>
					</div>
				</div>

				<div class="layer">
					<div class="layer-label">Core Concepts</div>
					<div class="path-grid">
						<a href="/blog/2026-04-17-the-wrong-owner" class="path-link">
							<div class="path-step">→</div>
							<div class="path-content">
								<div class="path-title">[draft] Transferring Responsibility</div>
								<p class="path-desc">Moving logic from probabilistic AI to deterministic code.</p>
							</div>
						</a>
						<a href="/blog/2026-03-20-three-levers" class="path-link">
							<div class="path-step">→</div>
							<div class="path-content">
								<div class="path-title">[draft] The Three Levers</div>
								<p class="path-desc">A diagnostic framework for debugging agent behavior.</p>
							</div>
						</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
