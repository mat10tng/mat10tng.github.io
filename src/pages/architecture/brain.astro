---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import brainData from '../../data/brain-evolution.json';

const phaseOrder = ['instrumentation', 'lifecycle', 'activation', 'self-improvement'] as const;
const verdictColors: Record<string, string> = {
  keep: '#22c55e',
  revert: '#ef4444',
  iterate: '#f59e0b',
  active: '#2563eb'
};
const verdictLabels: Record<string, string> = {
  keep: 'kept',
  revert: 'reverted',
  iterate: 'iterating',
  active: 'active'
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`the brain | ${SITE_TITLE}`} description="an Obsidian vault with 1400+ notes. it stores everything the system knows, and proposes changes to itself." />
		<style>
			/* layout */
			.brain-page { max-width: 800px; margin: 0 auto; padding: 2rem 1rem; }
			.back-link { font-size: 0.8rem; color: #999; text-decoration: none; }
			.back-link:hover { text-decoration: underline; }
			h1 { font-size: 1.2rem; margin-bottom: 0.25rem; }
			.intro { color: #666; font-size: 0.9rem; line-height: 1.6; margin-bottom: 2rem; }

			/* diagrams */
			.diagram-wrap { overflow-x: auto; margin-bottom: 1.5rem; }
			.diagram-wrap svg { display: block; max-width: 100%; height: auto; }
			.diagram-wrap svg text { font-family: system-ui, -apple-system, sans-serif; }
			.diagram-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #999; margin-bottom: 0.75rem; }

			/* phase groups */
			.phase-group { margin-bottom: 2.5rem; }
			.phase-header { margin-bottom: 1rem; }
			.phase-name { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #999; }
			.phase-desc { display: block; font-size: 0.85rem; color: #666; line-height: 1.5; margin-top: 0.25rem; }

			/* proposal cards */
			.proposal-card {
				border-left: 3px solid #ddd;
				padding: 0.75rem 1rem;
				margin-bottom: 0.75rem;
				background: #fafafa;
				border-radius: 0 4px 4px 0;
			}
			.proposal-meta { font-size: 0.75rem; color: #999; margin-bottom: 0.25rem; }
			.proposal-title { font-weight: 600; font-size: 0.9rem; margin-bottom: 0.35rem; }
			.proposal-change { font-size: 0.85rem; color: #555; line-height: 1.5; margin-bottom: 0.5rem; }
			.proposal-result { display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap; }
			.verdict-badge {
				font-size: 0.7rem; font-weight: 600; padding: 0.1rem 0.5rem;
				border-radius: 3px; white-space: nowrap;
			}
			.proposal-impact { font-size: 0.8rem; color: #888; font-style: italic; }

			/* health metrics */
			.health { margin-top: 3rem; }
			.health-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #999; margin-bottom: 1rem; }
			.health-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
			.metric-card { text-align: center; padding: 1rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 6px; }
			.metric-value { font-size: 1.5rem; font-weight: 700; color: #2563eb; }
			.metric-name { font-size: 0.75rem; color: #999; margin-top: 0.25rem; }

			@media (max-width: 750px) {
				.health-grid { grid-template-columns: repeat(2, 1fr); }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="brain-page">
				<a href="/architecture" class="back-link">&larr; architecture</a>
				<h1>the brain</h1>
				<p class="intro">
					an Obsidian vault with {brainData.current.notes}+ notes. it stores everything the system knows, and proposes changes to itself.
				</p>

				<!-- CONCEPTUAL DIAGRAM -->
				<div class="diagram-label">how it connects</div>
				<div class="diagram-wrap">
					<svg viewBox="0 0 560 100" width="560">
						<!-- Obsidian Vault -->
						<rect x="4" y="8" width="150" height="40" rx="8" fill="none" stroke="#2563eb" stroke-width="1.4"/>
						<text x="79" y="32" text-anchor="middle" font-size="11" font-weight="600" fill="#2563eb">Obsidian Vault</text>

						<!-- KB Server -->
						<rect x="205" y="8" width="150" height="40" rx="8" fill="none" stroke="#333" stroke-width="1.2"/>
						<text x="280" y="32" text-anchor="middle" font-size="11" font-weight="600" fill="#333">KB Server</text>

						<!-- Claude Session -->
						<rect x="406" y="8" width="150" height="40" rx="8" fill="none" stroke="#333" stroke-width="1.2"/>
						<text x="481" y="32" text-anchor="middle" font-size="11" font-weight="600" fill="#333">Claude Session</text>

						<!-- arrows: vault <-> KB -->
						<line x1="158" y1="22" x2="201" y2="22" stroke="#bbb" stroke-width="1"/>
						<polygon points="199,19 205,22 199,25" fill="#bbb"/>
						<line x1="201" y1="36" x2="158" y2="36" stroke="#bbb" stroke-width="1"/>
						<polygon points="160,33 154,36 160,39" fill="#bbb"/>
						<text x="180" y="17" text-anchor="middle" font-size="6.5" fill="#aaa">recall</text>
						<text x="180" y="48" text-anchor="middle" font-size="6.5" fill="#aaa">store</text>

						<!-- arrows: KB <-> Claude -->
						<line x1="359" y1="22" x2="402" y2="22" stroke="#bbb" stroke-width="1"/>
						<polygon points="400,19 406,22 400,25" fill="#bbb"/>
						<line x1="402" y1="36" x2="359" y2="36" stroke="#bbb" stroke-width="1"/>
						<polygon points="361,33 355,36 361,39" fill="#bbb"/>
						<text x="380" y="17" text-anchor="middle" font-size="6.5" fill="#aaa">load</text>
						<text x="380" y="48" text-anchor="middle" font-size="6.5" fill="#aaa">brief</text>

						<!-- evolution engine -->
						<rect x="30" y="62" width="100" height="28" rx="6" fill="none" stroke="#2563eb" stroke-width="1.1"/>
						<text x="80" y="80" text-anchor="middle" font-size="9" fill="#2563eb">&#8635; evolution engine</text>
						<line x1="79" y1="48" x2="79" y2="58" stroke="#2563eb" stroke-width="0.8"/>
						<polygon points="76,56 79,62 82,56" fill="#2563eb"/>
					</svg>
				</div>

				<!-- ANATOMY DIAGRAM -->
				<div class="diagram-label">what's inside</div>
				<div class="diagram-wrap">
					<svg viewBox="0 0 560 220" width="560">
						<!-- outer vault -->
						<rect x="4" y="4" width="552" height="212" rx="8" fill="none" stroke="#2563eb" stroke-width="1.4"/>
						<text x="20" y="24" font-size="12" font-weight="600" fill="#2563eb">Obsidian Vault</text>

						<!-- _system section -->
						<rect x="16" y="36" width="164" height="140" rx="6" fill="#f8faff" stroke="#ddd" stroke-width="0.8"/>
						<text x="28" y="54" font-size="10" font-weight="600" fill="#555">_system/</text>
						<text x="28" y="72" font-size="8.5" fill="#888">evolution/</text>
						<text x="40" y="86" font-size="7.5" fill="#aaa">proposals, experiments</text>
						<text x="40" y="98" font-size="7.5" fill="#aaa">changelog</text>
						<text x="28" y="116" font-size="8.5" fill="#888">meta-brain/</text>
						<text x="40" y="130" font-size="7.5" fill="#aaa">dashboard, health</text>
						<text x="28" y="148" font-size="8.5" fill="#888">claude-config/</text>
						<text x="40" y="162" font-size="7.5" fill="#aaa">CLAUDE.md (bootloader)</text>

						<!-- projects section -->
						<rect x="196" y="36" width="200" height="140" rx="6" fill="#f8faff" stroke="#ddd" stroke-width="0.8"/>
						<text x="208" y="54" font-size="10" font-weight="600" fill="#555">projects/</text>
						<text x="208" y="72" font-size="8.5" fill="#888">ClarityProject/</text>
						<text x="220" y="86" font-size="7.5" fill="#aaa">sessions, fixes, decisions</text>
						<text x="208" y="104" font-size="8.5" fill="#888">knowledge-base-server/</text>
						<text x="220" y="118" font-size="7.5" fill="#aaa">architecture, tooling</text>
						<text x="208" y="136" font-size="8.5" fill="#888">global/</text>
						<text x="220" y="150" font-size="7.5" fill="#aaa">rules, workflows, lessons</text>
						<!-- graduation arrow -->
						<text x="220" y="166" font-size="7.5" fill="#2563eb">&uarr; rules graduate to global</text>

						<!-- archive section -->
						<rect x="412" y="36" width="132" height="140" rx="6" fill="#f8faff" stroke="#ddd" stroke-width="0.8"/>
						<text x="424" y="54" font-size="10" font-weight="600" fill="#555">12_archive/</text>
						<text x="424" y="74" font-size="8.5" fill="#888">compacted sessions</text>
						<text x="424" y="90" font-size="8.5" fill="#888">stale notes</text>
						<text x="424" y="110" font-size="7.5" fill="#aaa">still searchable</text>
						<text x="424" y="124" font-size="7.5" fill="#aaa">not loaded by default</text>

						<!-- bottom summary -->
						<text x="280" y="198" text-anchor="middle" font-size="8" fill="#999">knowledge flows in through projects, graduates to global, archives when stale</text>
					</svg>
				</div>

				<!-- PROPOSAL TIMELINE -->
				<div class="diagram-label">evolution proposals</div>
				{phaseOrder.map(phase => {
					const phaseProposals = brainData.proposals.filter((p: any) => p.phase === phase);
					if (phaseProposals.length === 0) return null;
					return (
						<div class="phase-group">
							<div class="phase-header">
								<span class="phase-name">{phase.replace('-', ' ')}</span>
								<span class="phase-desc">{(brainData.phases as any)[phase]}</span>
							</div>
							{phaseProposals.map((p: any) => (
								<div class="proposal-card" style={`border-left-color: ${verdictColors[p.verdict]}`}>
									<div class="proposal-meta">{p.id} &middot; {p.date}</div>
									<div class="proposal-title">{p.title}</div>
									<div class="proposal-change">{p.change}</div>
									<div class="proposal-result">
										<span class="verdict-badge" style={`background: ${verdictColors[p.verdict]}20; color: ${verdictColors[p.verdict]}`}>
											{verdictLabels[p.verdict]}
										</span>
										<span class="proposal-impact">{p.impact}</span>
									</div>
								</div>
							))}
						</div>
					);
				})}

				<!-- CURRENT HEALTH -->
				<section class="health">
					<div class="health-label">current health</div>
					<div class="health-grid">
						<div class="metric-card">
							<div class="metric-value">{brainData.current.compounding}%</div>
							<div class="metric-name">compounding</div>
						</div>
						<div class="metric-card">
							<div class="metric-value">{brainData.current.notes}</div>
							<div class="metric-name">total notes</div>
						</div>
						<div class="metric-card">
							<div class="metric-value">{brainData.current.rules}</div>
							<div class="metric-name">rules</div>
						</div>
						<div class="metric-card">
							<div class="metric-value">{brainData.current.captureCompleteness}%</div>
							<div class="metric-name">capture completeness</div>
						</div>
					</div>
				</section>
			</section>
		</main>
		<Footer />
	</body>
</html>
