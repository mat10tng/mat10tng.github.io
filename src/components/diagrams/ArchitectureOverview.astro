---
const { step = 0 } = Astro.props;
import historyData from '../../data/history.json';
---

<div style="margin: 2rem 0; padding: 2rem; background: #fff; border: 1px solid #eee; border-radius: 8px;">
    <div style="font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #999; margin-bottom: 1.5rem; text-align: center;">
        {step === 1 && "Memory Setup"}
        {step === 2 && "Workflow Setup"}
        {step === 3 && "Architecture: Data-Driven Evolution"}
        {step === 0 && "System Architecture Overview"}
    </div>

    <svg viewBox="0 0 560 230" width="100%" style="display: block; max-width: 600px; margin: 0 auto;">
        <!-- ARCHITECT -->
        <a href="https://www.linkedin.com/in/tuan-nguyen-it-ot/" target="_blank">
            <circle cx="280" cy="12" r="6" fill="none" stroke="#333" stroke-width="1.5"/>
            <path d="M 268 32 Q 280 20 292 32" fill="none" stroke="#333" stroke-width="1.5"/>
            <text x="280" y="44" text-anchor="middle" font-size="11" font-weight="600" fill="#333">Architect</text>
            <text x="280" y="54" text-anchor="middle" font-size="7" fill="#999">Directs Goals</text>
        </a>

        {step === 1 && (
            <g>
                <!-- Memory with folder structure -->
                <rect x="4" y="110" width="156" height="106" rx="8" fill="none" stroke="#2563eb" stroke-width="2"/>
                <text x="82" y="128" text-anchor="middle" font-size="14" font-weight="700" fill="#2563eb">Memory</text>

                <!-- folder representation -->
                <rect x="14" y="135" width="60" height="15" rx="2" fill="none" stroke="#2563eb" stroke-width="0.5" stroke-dasharray="2 1"/>
                <text x="44" y="145" text-anchor="middle" font-size="7" fill="#2563eb">/sessions</text>
                <rect x="82" y="135" width="60" height="15" rx="2" fill="none" stroke="#2563eb" stroke-width="0.5" stroke-dasharray="2 1"/>
                <text x="112" y="145" text-anchor="middle" font-size="7" fill="#2563eb">/lessons</text>
                <rect x="38" y="155" width="80" height="15" rx="2" fill="none" stroke="#2563eb" stroke-width="0.5" stroke-dasharray="2 1"/>
                <text x="78" y="165" text-anchor="middle" font-size="7" fill="#2563eb">state.json</text>

                <!-- LLM -->
                <rect x="400" y="110" width="156" height="106" rx="8" fill="none" stroke="#333" stroke-width="1.5"/>
                <text x="478" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#333">LLM</text>
                <text x="478" y="145" text-anchor="middle" font-size="8" fill="#888">Reasoning unit</text>

                <rect x="410" y="152" width="136" height="16" rx="2" fill="#f8f9fa" stroke="#2563eb" stroke-width="0.8" stroke-dasharray="2 1"/>
                <text x="478" y="163" text-anchor="middle" font-size="8" font-weight="600" fill="#2563eb">System Rules</text>

                <path d="M 205 22 L 82 22 L 82 110" fill="none" stroke="#ddd" stroke-width="1.2" stroke-dasharray="2 2"/>
                <path d="M 355 22 L 478 22 L 478 110" fill="none" stroke="#ddd" stroke-width="1.2" stroke-dasharray="2 2"/>
                <text x="280" y="68" text-anchor="middle" font-size="8" fill="#aaa">Manual Sync</text>
                <line x1="280" y1="58" x2="280" y2="110" stroke="#bbb" stroke-width="1.5" stroke-dasharray="4 2"/>
            </g>
        )}

        {step === 2 && (
            <g>
                <!-- Memory -->
                <rect x="4" y="110" width="156" height="106" rx="8" fill="none" stroke="#2563eb" stroke-width="2"/>
                <text x="82" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#2563eb">Memory</text>
                <text x="82" y="145" text-anchor="middle" font-size="8" fill="#888">Library</text>

                <!-- Workflow -->
                <rect x="202" y="110" width="156" height="106" rx="8" fill="none" stroke="#2563eb" stroke-width="2"/>
                <text x="280" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#2563eb">Workflow</text>
                <text x="280" y="145" text-anchor="middle" font-size="8" fill="#888">Use the notes</text>

                <rect x="215" y="154" width="56" height="14" rx="2" fill="#f8f9fa" stroke="#2563eb" stroke-width="0.7"/>
                <text x="243" y="164" text-anchor="middle" font-size="7" fill="#2563eb">start</text>
                <rect x="288" y="154" width="56" height="14" rx="2" fill="#f8f9fa" stroke="#2563eb" stroke-width="0.7"/>
                <text x="316" y="164" text-anchor="middle" font-size="7" fill="#2563eb">save</text>

                <!-- LLM -->
                <rect x="400" y="110" width="156" height="106" rx="8" fill="none" stroke="#333" stroke-width="1.5"/>
                <text x="478" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#333">LLM</text>
                <text x="478" y="145" text-anchor="middle" font-size="8" fill="#888">Does the work</text>

                <line x1="160" y1="140" x2="202" y2="140" stroke="#bbb" stroke-width="1.5"/>
                <line x1="358" y1="140" x2="400" y2="140" stroke="#bbb" stroke-width="1.5"/>
                <text x="181" y="135" text-anchor="middle" font-size="8" fill="#999">fetch</text>
                <text x="379" y="135" text-anchor="middle" font-size="8" fill="#999">mode</text>

                <line x1="280" y1="58" x2="280" y2="110" stroke="#bbb" stroke-width="1.5"/>
                <polygon points="276,108 280,116 284,108" fill="#bbb"/>
                <text x="280" y="222" text-anchor="middle" font-size="9" font-weight="700" fill="#2563eb">Start -> Work -> Check -> Save</text>
            </g>
        )}

        {(step === 3 || step === 0) && (
            <g>
                <!-- Memory -->
                <rect x="4" y="110" width="156" height="106" rx="8" fill="none" stroke="#2563eb" stroke-width="2"/>
                <text x="82" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#2563eb">Memory</text>
                <text x="82" y="145" text-anchor="middle" font-size="8" fill="#888">Storage & State</text>

                <!-- Interface -->
                <rect x="202" y="110" width="156" height="106" rx="8" fill="none" stroke="#333" stroke-width="1.5"/>
                <text x="280" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#333">Interface</text>
                <text x="280" y="145" text-anchor="middle" font-size="8" fill="#888">Automation (MCP)</text>

                <!-- LLM -->
                <rect x="400" y="110" width="156" height="106" rx="8" fill="none" stroke="#333" stroke-width="1.5"/>
                <text x="478" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#333">LLM</text>
                <text x="478" y="145" text-anchor="middle" font-size="8" fill="#888">Reasoning unit</text>

                <rect x="410" y="152" width="136" height="16" rx="2" fill="#f8f9fa" stroke="#2563eb" stroke-width="0.8" stroke-dasharray="2 1"/>
                <text x="478" y="163" text-anchor="middle" font-size="8" font-weight="600" fill="#2563eb">System Rules</text>

                <line x1="160" y1="140" x2="202" y2="140" stroke="#bbb" stroke-width="1.5"/>
                <line x1="358" y1="140" x2="400" y2="140" stroke="#bbb" stroke-width="1.5"/>
                <text x="181" y="135" text-anchor="middle" font-size="8" fill="#999">auto</text>
                <text x="379" y="135" text-anchor="middle" font-size="8" fill="#999">auto</text>

                <line x1="280" y1="58" x2="280" y2="110" stroke="#bbb" stroke-width="1.5"/>
                <polygon points="276,108 280,116 284,108" fill="#bbb"/>

                {step === 3 && (
                    <g>
                        <text x="280" y="222" text-anchor="middle" font-size="9" font-weight="700" fill="#2563eb">Data-Driven Improvement</text>
                        <path d="M 82 216 Q 280 240 478 216" fill="none" stroke="#2563eb" stroke-width="1.2" stroke-dasharray="2 1"/>
                    </g>
                )}
            </g>
        )}
    </svg>
</div>
