---
const { step = 0 } = Astro.props;
import historyData from '../../data/history.json';
---

<div style="margin: 2rem 0; padding: 2rem; background: #fff; border: 1px solid #eee; border-radius: 8px;">
    <div style="font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #999; margin-bottom: 1.5rem; text-align: center;">
        {step === 1 && "Step 01: Baseline Interaction"}
        {step === 2 && "Step 02: Introduction of the Vault"}
        {step === 3 && "Step 03: The Feedback Mechanism"}
        {step === 4 && "Step 04: Full Automation (MCP)"}
        {step === 0 && "System Architecture Overview"}
    </div>
    
    <svg viewBox="0 0 560 230" width="100%" style="display: block; max-width: 600px; margin: 0 auto;">
        <!-- HUMAN ARCHITECT (Always Present) -->
        <a href="https://www.linkedin.com/in/tuan-nguyen-it-ot/" target="_blank">
            <rect x="205" y="2" width="150" height="40" rx="20" fill="none" stroke="#333" stroke-width="1.5" stroke-dasharray="4 2"/>
            <text x="280" y="22" text-anchor="middle" font-size="12" font-weight="600" fill="#333">Human Architect</text>
            <text x="280" y="34" text-anchor="middle" font-size="8" fill="#888">decision maker</text>
        </a>

        {step === 1 && (
            <!-- STEP 1: Just Human + Worker + Bootloader -->
            <g>
                <rect x="202" y="110" width="156" height="80" rx="8" fill="none" stroke="#333" stroke-width="1.5"/>
                <text x="280" y="135" text-anchor="middle" font-size="14" font-weight="700" fill="#333">the worker</text>
                <text x="280" y="150" text-anchor="middle" font-size="9" fill="#888">Claude (session)</text>
                
                <line x1="280" y1="42" x2="280" y2="110" stroke="#bbb" stroke-width="1.5"/>
                <polygon points="276,108 280,116 284,108" fill="#bbb"/>
                <text x="290" y="80" font-size="9" fill="#2563eb" font-weight="600">CLAUDE.md + skills</text>
            </g>
        )}

        {step === 2 && (
            <!-- STEP 2: Adding the Vault (Manual interaction) -->
            <g>
                <!-- the vault -->
                <rect x="4" y="110" width="156" height="106" rx="8" fill="none" stroke="#2563eb" stroke-width="2"/>
                <text x="82" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#2563eb">the vault</text>
                <text x="82" y="147" text-anchor="middle" font-size="9" fill="#888">file system</text>
                
                <!-- the worker -->
                <rect x="400" y="110" width="156" height="106" rx="8" fill="none" stroke="#333" stroke-width="1.5"/>
                <text x="478" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#333">the worker</text>
                
                <!-- manual paths via human -->
                <path d="M 205 22 L 82 22 L 82 110" fill="none" stroke="#ddd" stroke-width="1.2" stroke-dasharray="2 2"/>
                <path d="M 355 22 L 478 22 L 478 110" fill="none" stroke="#ddd" stroke-width="1.2" stroke-dasharray="2 2"/>
                <text x="280" y="60" text-anchor="middle" font-size="9" fill="#aaa">human manually syncs context</text>
            </g>
        )}

        {step === 3 && (
            <!-- STEP 3: Feedback Loop / Graduation -->
            <g>
                <rect x="4" y="110" width="156" height="106" rx="8" fill="none" stroke="#2563eb" stroke-width="2"/>
                <text x="82" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#2563eb">the vault</text>
                <rect x="400" y="110" width="156" height="106" rx="8" fill="none" stroke="#333" stroke-width="1.5"/>
                <text x="478" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#333">the worker</text>
                
                <!-- loop -->
                <path d="M 400 160 L 160 160" fill="none" stroke="#2563eb" stroke-width="1.5"/>
                <polygon points="168,157 160,160 168,163" fill="#2563eb"/>
                <text x="280" y="155" text-anchor="middle" font-size="9" fill="#2563eb" font-weight="600">log session</text>
                
                <path d="M 82 216 Q 280 250 478 216" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-dasharray="4 2"/>
                <text x="280" y="215" text-anchor="middle" font-size="9" fill="#2563eb">graduate rules</text>
            </g>
        )}

        {(step === 4 || step === 0) && (
            <!-- STEP 4 / FINAL: The Bridge (MCP) -->
            <g>
                <!-- the vault -->
                <rect x="4" y="110" width="156" height="106" rx="8" fill="none" stroke="#2563eb" stroke-width="2"/>
                <text x="82" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#2563eb">the vault</text>
                
                <!-- the bridge -->
                <rect x="202" y="110" width="156" height="106" rx="8" fill="none" stroke="#333" stroke-width="1.5"/>
                <text x="280" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#333">the bridge</text>
                <text x="280" y="147" text-anchor="middle" font-size="9" fill="#888">MCP / Automation</text>

                <!-- the worker -->
                <rect x="400" y="110" width="156" height="106" rx="8" fill="none" stroke="#333" stroke-width="1.5"/>
                <text x="478" y="132" text-anchor="middle" font-size="14" font-weight="700" fill="#333">the worker</text>

                <!-- automated arrows -->
                <line x1="160" y1="140" x2="202" y2="140" stroke="#bbb" stroke-width="1.5"/>
                <line x1="358" y1="140" x2="400" y2="140" stroke="#bbb" stroke-width="1.5"/>
                <text x="181" y="135" text-anchor="middle" font-size="8" fill="#999">auto</text>
                <text x="379" y="135" text-anchor="middle" font-size="8" fill="#999">auto</text>
                
                <!-- human link -->
                <line x1="280" y1="42" x2="280" y2="110" stroke="#bbb" stroke-width="1.5"/>
                <polygon points="276,108 280,116 284,108" fill="#bbb"/>
            </g>
        )}
    </svg>
</div>
