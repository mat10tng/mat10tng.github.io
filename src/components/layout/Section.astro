<div class="technical-section">
    <div class="insight">
        <slot name="insight" />
    </div>
    <div class="technical">
        <slot name="technical" />
    </div>
</div>

<style>
    .technical-section {
        margin-bottom: 3rem;
        padding-top: 1rem;
    }

    .insight {
        margin-bottom: 1.5rem;
    }

    .technical {
        background: #fdfdfd;
        border-left: 3px solid #eee;
        padding-left: 1.5rem;
    }
    
    /* On large screens, we still allow code to be distinct but keeping it single column flow for maximum focus */
    @media (min-width: 1000px) {
        .technical-section {
            max-width: 800px;
            margin: 0 auto 4rem;
        }
    }
</style>
