---
---
<div class="section-container">
    <div class="insight">
        <slot name="insight" />
    </div>
    <div class="technical">
        <slot name="technical" />
    </div>
</div>

<style>
    .section-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        margin-bottom: 2rem;
        align-items: start;
        border-top: 1px solid #f0f0f0;
        padding-top: 1.5rem;
    }

    @media (min-width: 1000px) {
        .section-container {
            grid-template-columns: 1fr 400px;
            gap: 3rem;
            max-width: 1000px;
            margin: 0 auto 2rem;
        }
    }

    .insight :global(h2), .insight :global(h3) {
        margin-top: 0;
        font-size: 1.1rem;
    }

    .insight :global(p) {
        margin: 0.5rem 0;
        font-size: 0.95rem;
    }

    .technical {
        position: sticky;
        top: 1rem;
    }

    .technical :global(pre) {
        margin: 0 !important;
        font-size: 0.85rem !important;
        padding: 1rem !important;
    }
</style>
